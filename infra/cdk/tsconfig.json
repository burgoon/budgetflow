{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node"],
    "outDir": "dist",
    "rootDir": ".",
    "noEmit": false,
    "isolatedModules": false,
    "noUncheckedIndexedAccess": false
  },
  "include": ["bin/**/*", "lib/**/*"]
}
